{
  "name": "@smoke/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "observe": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "run-session": "tsx src/cli/runSession.ts",
    "enqueue": "tsx src/cli/enqueue.ts",
    "report": "tsx src/cli/rebuildReport.ts",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint src --ext .ts",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "playwright": "^1.46.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  }
}

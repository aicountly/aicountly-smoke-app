# Dependencies
node_modules/
**/node_modules/
vendor/
**/vendor/

# Build outputs
dist/
build/
**/dist/
**/build/
.vite/
**/.vite/
*.tsbuildinfo

# Env / secrets
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Playwright
test-results/
playwright-report/
.playwright/

# Smoke reports (generated artefacts; keep folder via .gitkeep)
smoke-reports/**
!smoke-reports/.gitkeep

# CodeIgniter writable / runtime
backend/writable/cache/*
backend/writable/logs/*
backend/writable/session/*
backend/writable/uploads/*
backend/writable/debugbar/*
!backend/writable/cache/.gitkeep
!backend/writable/logs/.gitkeep
!backend/writable/session/.gitkeep
!backend/writable/uploads/.gitkeep

# Coverage
coverage/
.nyc_output/

# DB dumps
*.sqlite
*.sqlite3
*.db
